projection;
strict ( 2 );

define behavior for ZC_ACAD_CLASS alias Class
{
  use create;
  use update;
  use delete;

  use action lockClass;
  use action unlockClass;

  use association _Exam { create; }
}

define behavior for ZC_ACAD_EXAM alias Exam
{
  use update;
  use delete;

  use association _Class;
}